#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGINS_DIR="$(dirname "$SCRIPT_DIR")/plugins"

usage() {
  echo "Usage: install-skills <target>"
  echo ""
  echo "Targets:"
  echo "  opencode    ~/.config/opencode/skills/"
  echo "  codex       ~/.codex/skills/"
  exit 1
}

case "${1:-}" in
  opencode) DEST="$HOME/.config/opencode/skills" ;;
  codex)    DEST="$HOME/.codex/skills" ;;
  *)        usage ;;
esac

installed=0
for skill_md in "$PLUGINS_DIR"/*/skills/*/SKILL.md; do
  skill_dir="$(dirname "$skill_md")"
  skill_name="$(basename "$skill_dir")"
  mkdir -p "$DEST/$skill_name"
  # Copy SKILL.md plus any sibling files (LICENSE, reference/, etc.) — required
  # for license compliance on forked skills and for progressive-disclosure refs.
  cp -R "$skill_dir"/. "$DEST/$skill_name/"
  installed=$((installed + 1))
  echo "  $skill_name"
done

echo ""
echo "Installed $installed skills to $DEST"
