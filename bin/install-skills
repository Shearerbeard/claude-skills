#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
PLUGINS_DIR="$REPO_DIR/plugins"

OPENCODE_DIR="$HOME/.config/opencode/skills"
CODEX_DIR="$HOME/.codex/skills"

installed=0

for skill_md in "$PLUGINS_DIR"/*/skills/*/SKILL.md; do
  skill_name="$(basename "$(dirname "$skill_md")")"

  mkdir -p "$OPENCODE_DIR/$skill_name"
  cp "$skill_md" "$OPENCODE_DIR/$skill_name/SKILL.md"

  mkdir -p "$CODEX_DIR/$skill_name"
  cp "$skill_md" "$CODEX_DIR/$skill_name/SKILL.md"

  installed=$((installed + 1))
  echo "  $skill_name"
done

echo ""
echo "Installed $installed skills to:"
echo "  OpenCode: $OPENCODE_DIR"
echo "  Codex:    $CODEX_DIR"
